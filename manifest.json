{
  "manifest_version": 3,
  "name": "CSS Scratchpad",
  "version": "1.1.0",
  "description": "Temporarily apply custom CSS to any webpage.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "CSS Scratchpad",
    "default_icon": {
      "16": "icons/action16.png",
      "32": "icons/action32.png",
      "48": "icons/action48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/action16.png",
    "32": "icons/action32.png",
    "48": "icons/action48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/action48.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}