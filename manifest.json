{
  "manifest_version": 3,
  "name": "CSS Scratchpad",
  "version": "0.1.0",
  "description": "Temporarily apply custom CSS to the current page.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "CSS Scratchpad",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}